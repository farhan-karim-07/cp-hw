public ListNode removeNodes(ListNode head) {
    Stack<ListNode> st = new Stack<>();
    ListNode temp = head;

    // push all nodes to stack
    while (temp != null) {
        st.push(temp);
        temp = temp.next;
    }

    // pop the top (rightmost node, always stays)
    ListNode tail = st.peek();
    st.pop();
    int mx = tail.val;
    ListNode top = null;

    // process remaining nodes
    while (st.size() > 0) {
        top = st.peek();
        st.pop();
        if (top.val >= mx) {
            mx = top.val;
            top.next = tail;
            tail = top;
        }
    }

    return tail;
}
```

